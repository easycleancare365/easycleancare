---
import { services, stats } from '../data/site';
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
---
<section id="services" class="py-20 md:py-28 bg-cream">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <SectionHeading
      eyebrow="Our Services"
      title="입주에 필요한 모든 케어를 <span class='text-brand'>한 곳에서</span>"
      desc="청소부터 시공까지, 신규 입주에 꼭 필요한 5가지 홈케어 서비스를 전문 인력이 책임집니다."
    />

    <!-- 서비스 카드 -->
    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s, i) => (
        <article
          class="reveal group relative flex flex-col rounded-2xl bg-surface border hairline p-7 hover:border-brand/30 hover:shadow-[0_20px_40px_-24px_rgba(20,52,43,0.4)] hover:-translate-y-1 transition-all duration-300"
          data-delay={String((i % 3) + 1)}
        >
          <span class="grid place-items-center h-12 w-12 rounded-xl bg-brand-soft text-brand group-hover:bg-brand group-hover:text-cream transition-colors">
            <Icon name={s.icon} class="w-6 h-6" />
          </span>
          <h3 class="mt-5 text-xl font-bold text-ink">{s.title}</h3>
          <p class="mt-1 text-sm font-medium text-brand-500">{s.short}</p>
          <p class="mt-3 text-sm leading-relaxed text-muted">{s.desc}</p>
          <ul class="mt-5 space-y-2 border-t hairline pt-5">
            {s.points.map((p) => (
              <li class="flex items-start gap-2 text-sm text-ink/80">
                <Icon name="check" class="w-4 h-4 mt-0.5 text-brand-500 shrink-0" />
                {p}
              </li>
            ))}
          </ul>
        </article>
      ))}

      <!-- 통합 상담 안내 카드 -->
      <article class="reveal relative flex flex-col justify-between rounded-2xl bg-brand text-cream p-7 overflow-hidden" data-delay="3">
        <div class="pointer-events-none absolute -right-10 -bottom-10 h-40 w-40 rounded-full bg-cream/10 blur-2xl"></div>
        <div>
          <h3 class="text-xl font-bold">어떤 서비스가 필요할지<br />모르시겠나요?</h3>
          <p class="mt-3 text-sm leading-relaxed text-cream/75">
            평형과 입주 일정만 알려주시면, 집 상태에 맞는 최적의 홈케어 구성을 제안해 드립니다.
          </p>
        </div>
        <a href="#contact" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-cream">
          맞춤 상담 받기
          <Icon name="arrow" class="w-4 h-4" />
        </a>
      </article>
    </div>

    <!-- 실적 카운트업 -->
    <div class="reveal mt-16 grid grid-cols-2 lg:grid-cols-4 gap-px rounded-2xl overflow-hidden border hairline bg-line">
      {stats.map((st) => (
        <div class="bg-surface px-6 py-8 text-center">
          <p class="text-3xl md:text-4xl font-bold text-brand tabular-nums">
            <span data-count={String(st.value)}>0</span>{st.suffix}
          </p>
          <p class="mt-2 text-sm text-muted">{st.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
