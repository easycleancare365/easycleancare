---
import { contact } from '../data/site';
import Icon from './Icon.astro';
---
<!-- 모바일 하단 고정 CTA -->
<div class="lg:hidden fixed bottom-0 inset-x-0 z-50 px-3 pb-[env(safe-area-inset-bottom)]">
  <div class="mb-3 grid grid-cols-3 gap-2 rounded-2xl bg-surface/95 backdrop-blur-md p-2 shadow-[0_8px_30px_rgba(20,52,43,0.18)] border hairline">
    <a
      href={contact.kakaoUrl}
      target="_blank"
      rel="noopener"
      class="flex flex-col items-center justify-center gap-1 rounded-xl bg-[#FEE500] text-[#3A2929] py-2.5 active:scale-95 transition-transform"
    >
      <Icon name="chat" class="w-5 h-5" />
      <span class="text-xs font-bold">카카오톡 상담</span>
    </a>
    <a
      href={`tel:${contact.phoneRaw}`}
      class="flex flex-col items-center justify-center gap-1 rounded-xl bg-brand text-cream py-2.5 active:scale-95 transition-transform"
    >
      <Icon name="phone" class="w-5 h-5" />
      <span class="text-xs font-bold">전화 문의</span>
    </a>
    <a
      href={contact.smsHref}
      class="flex flex-col items-center justify-center gap-1 rounded-xl bg-brand-soft text-brand py-2.5 active:scale-95 transition-transform"
    >
      <Icon name="message" class="w-5 h-5" />
      <span class="text-xs font-bold">문자 견적</span>
    </a>
  </div>
</div>
