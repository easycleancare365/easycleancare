---
/** 인라인 SVG 아이콘 (외부 라이브러리 없이 경량 렌더링) */
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'w-6 h-6' } = Astro.props;

// stroke 기반 라인 아이콘 (프리미엄 미니멀 톤)
const paths: Record<string, string> = {
  sparkle:
    '<path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z"/><path d="M19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8L19 15z"/>',
  home:
    '<path d="M3 10.5L12 4l9 6.5"/><path d="M5 9.5V20h14V9.5"/><path d="M9.5 20v-5.5h5V20"/>',
  grid:
    '<rect x="4" y="4" width="16" height="16" rx="1.5"/><path d="M4 10h16M4 14h16M10 4v16M14 4v16"/>',
  shield:
    '<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9.2 12l2 2 3.6-3.8"/>',
  leaf:
    '<path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 7-6 11-8"/>',
  phone:
    '<path d="M4.5 5.5c0-.8.7-1.5 1.5-1.5h2.2c.6 0 1.1.4 1.3 1l.9 3c.1.5 0 1-.4 1.4l-1.3 1.2a12 12 0 005 5l1.2-1.3c.4-.4.9-.5 1.4-.4l3 .9c.6.2 1 .7 1 1.3V19c0 .8-.7 1.5-1.5 1.5C10.6 20.5 4.5 14.4 4.5 6.5z"/>',
  chat:
    '<path d="M4 6.5C4 5.1 5.1 4 6.5 4h11C18.9 4 20 5.1 20 6.5v7c0 1.4-1.1 2.5-2.5 2.5H10l-4 4v-4h-.5C4.1 16 4 14.9 4 13.5z"/>',
  message:
    '<rect x="4" y="5" width="16" height="14" rx="2"/><path d="M4.5 6.5L12 12l7.5-5.5"/>',
  check:
    '<path d="M5 12.5l4.5 4.5L19 7.5"/>',
  arrow:
    '<path d="M5 12h14M13 6l6 6-6 6"/>',
  clock:
    '<circle cx="12" cy="12" r="8"/><path d="M12 8v4.5l3 2"/>',
  pin:
    '<path d="M12 21s7-6 7-11a7 7 0 10-14 0c0 5 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  star:
    '<path d="M12 4l2.4 5 5.6.7-4 3.9 1 5.4-5-2.7-5 2.7 1-5.4-4-3.9 5.6-.7z"/>',
  plus: '<path d="M12 5v14M5 12h14"/>',
};
const d = paths[name] ?? paths.check;
---
<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>
